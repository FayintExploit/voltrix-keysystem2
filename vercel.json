{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "getkey.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/start",    "dest": "/api/start.js" },
    { "src": "/api/token",    "dest": "/api/token.js" },
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/validate", "dest": "/api/validate.js" },
    { "src": "/(.*)",         "dest": "/getkey.html" }
  ]
}
